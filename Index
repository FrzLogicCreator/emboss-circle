<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Emboss Circle</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --green:#104237;
  --green2:#1a5c4a;
  --pink:#eda8cb;
  --pink2:#d4789e;
  --pearl:#f0efef;
  --cream:#f5eed9;
  --white:#ffffff;
  --slate:#5f6b64;
  --border:#dddad3;
  --red:#c0392b;
  --green-light:#e8f4f0;
}
html,body{
  min-height:100vh;
  font-family:'Segoe UI',system-ui,sans-serif;
  background:var(--cream);
  -webkit-tap-highlight-color:transparent;
}

/* ── SCREENS ── */
.screen{display:none;min-height:100vh;flex-direction:column;align-items:center}
.screen.active{display:flex;animation:fadeUp .3s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

/* ════════════════════════════════
   TOP HEADER — WHITE CARD
   Logo visible: green on white
════════════════════════════════ */
/* ══ UNIFIED GREEN HEADER ══ */
.top-header{
  width:100%;
  background:var(--green);
  padding:22px 20px 20px;
  display:flex;
  flex-direction:column;
  align-items:center;
  position:relative;
  overflow:hidden;
  border-bottom:4px solid var(--pink);
}
/* decorative circles inside header */
.top-header::before{
  content:'';position:absolute;
  right:-30px;top:-30px;
  width:100px;height:100px;
  border-radius:50%;
  background:rgba(237,168,203,.1);
  pointer-events:none;
}
.top-header::after{
  content:'';position:absolute;
  left:-20px;bottom:-20px;
  width:70px;height:70px;
  border-radius:50%;
  background:rgba(255,255,255,.05);
  pointer-events:none;
}
/* "LOYALTY REWARDS PROGRAM" label above logo */
.header-top-label{
  color:rgba(255,255,255,.75);
  font-size:0.65rem;
  font-weight:800;
  letter-spacing:.2em;
  text-transform:uppercase;
  margin-bottom:12px;
  position:relative;z-index:1;
}
/* White oval behind logo */
.logo-oval{
  background:var(--white);
  border-radius:60px;
  padding:10px 28px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  box-shadow:0 2px 14px rgba(0,0,0,.15);
  position:relative;z-index:1;
  margin-bottom:12px;
}
.logo-img{
  height:44px;
  width:auto;
  object-fit:contain;
  display:block;
  /* Logo is green on white — perfect contrast, no filter needed */
}
/* Branch pill */
.branch-pill{
  display:inline-block;
  background:var(--pink);
  color:var(--green);
  font-size:0.68rem;
  font-weight:800;
  letter-spacing:.1em;
  text-transform:uppercase;
  padding:4px 16px;
  border-radius:30px;
  position:relative;z-index:1;
}
/* No hero-band needed anymore — header is all-in-one */
.hero-band{ display:none; }
.hero-tagline-img{ display:none; }

/* ════════════════════════════════
   MAIN CONTENT AREA
════════════════════════════════ */
.content{
  width:100%;
  max-width:420px;
  padding:20px 16px 32px;
  display:flex;
  flex-direction:column;
  align-items:stretch;
  gap:14px;
}

/* ════════════════════════════════
   CARD
════════════════════════════════ */
.card{
  background:var(--white);
  border-radius:18px;
  padding:24px 20px;
  box-shadow:0 2px 16px rgba(16,66,55,.07);
  border:1px solid rgba(16,66,55,.05);
}
.card-cream{background:var(--cream)}
.card-green{background:var(--green)}

/* ════════════════════════════════
   FIELD
════════════════════════════════ */
.field-label{
  display:block;
  font-size:0.75rem;
  font-weight:800;
  color:var(--green);
  margin-bottom:8px;
  letter-spacing:.06em;
  text-transform:uppercase;
}
.field-wrap{position:relative}
.f-prefix{
  position:absolute;
  left:14px;top:50%;transform:translateY(-50%);
  font-size:1rem;pointer-events:none;line-height:1;
}
.input{
  width:100%;
  padding:15px 14px 15px 46px;
  font-size:1.25rem;
  font-weight:700;
  color:var(--green);
  background:var(--pearl);
  border:2.5px solid var(--border);
  border-radius:13px;
  outline:none;
  -webkit-appearance:none;
  transition:border .2s,box-shadow .2s;
  letter-spacing:.06em;
}
.input.plain{padding-left:14px;font-size:1rem;letter-spacing:.01em}
.input:focus{border-color:var(--pink);box-shadow:0 0 0 3px rgba(237,168,203,.22)}
.input.has-error{border-color:var(--red)}
.err-text{
  color:var(--red);font-size:0.75rem;
  font-weight:600;margin-top:6px;
  display:none;
}
.err-text.show{display:block}

/* ════════════════════════════════
   BUTTONS
════════════════════════════════ */
.btn{
  width:100%;padding:16px 20px;
  font-size:0.95rem;font-weight:800;
  border:none;border-radius:13px;cursor:pointer;
  transition:all .18s;
  display:flex;align-items:center;justify-content:center;gap:8px;
  -webkit-appearance:none;letter-spacing:.02em;
}
.btn:active:not(:disabled){transform:scale(.97)}
.btn:disabled{opacity:.5;cursor:not-allowed;transform:none}

.btn-green{background:var(--green);color:var(--white)}
.btn-green:hover:not(:disabled){background:var(--green2)}

.btn-pink{background:var(--pink);color:var(--green)}
.btn-pink:hover:not(:disabled){background:var(--pink2);color:var(--white)}

.btn-outline{background:transparent;color:var(--green);border:2.5px solid var(--green)}
.btn-outline:hover:not(:disabled){background:var(--green);color:var(--white)}

.btn-ghost{
  background:none;border:none;
  color:var(--slate);font-size:0.83rem;
  font-weight:600;cursor:pointer;padding:10px;
  font-family:inherit;width:100%;
}
.btn-ghost:hover{color:var(--green)}

.btn-danger{background:var(--red);color:var(--white)}
.btn-danger:hover:not(:disabled){background:#a93226}

/* spinner inside btn */
.spin{
  display:none;width:18px;height:18px;flex-shrink:0;
  border:2.5px solid rgba(255,255,255,.3);
  border-top-color:var(--white);
  border-radius:50%;
  animation:rot .7s linear infinite;
}
.btn-pink .spin{border-color:rgba(16,66,55,.2);border-top-color:var(--green)}
.btn.busy .btn-txt{display:none}
.btn.busy .spin{display:block}
@keyframes rot{to{transform:rotate(360deg)}}

/* ════════════════════════════════
   STAMP CARD
════════════════════════════════ */
.stamp-card{
  background:var(--green);
  border-radius:16px;
  padding:20px 18px 18px;
  position:relative;
  overflow:hidden;
}
.sc-top{
  display:flex;align-items:center;
  justify-content:space-between;
  margin-bottom:14px;
}
.sc-label{
  color:rgba(255,255,255,.65);
  font-size:0.62rem;font-weight:800;
  letter-spacing:.16em;text-transform:uppercase;
}
.sc-badge{
  background:var(--pink);color:var(--green);
  font-size:0.62rem;font-weight:800;
  padding:3px 10px;border-radius:20px;
  letter-spacing:.04em;text-transform:uppercase;
}
.stamps-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:10px;
  margin-bottom:14px;
}
.sdot{
  aspect-ratio:1/1;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;
}
.sdot.on{
  background:var(--pink);
  box-shadow:0 2px 8px rgba(237,168,203,.5);
}
.sdot.off{
  background:rgba(255,255,255,.1);
  border:1.5px dashed rgba(255,255,255,.2);
}
.sdot.pop{animation:stampPop .45s cubic-bezier(.36,.07,.19,.97) both}
@keyframes stampPop{
  0%{transform:scale(0) rotate(-20deg)}
  65%{transform:scale(1.25) rotate(5deg)}
  100%{transform:scale(1) rotate(0)}
}
.sc-progress{
  text-align:center;color:rgba(255,255,255,.7);
  font-size:0.76rem;font-weight:600;
}
.sc-progress b{color:var(--pink)}

/* ghost character on stamp card */
.sc-char{
  position:absolute;right:-12px;bottom:0;
  height:96px;object-fit:contain;
  opacity:.08;pointer-events:none;
}

/* ════════════════════════════════
   STATS ROW
════════════════════════════════ */
.stats{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:8px;
}
.stat{
  background:var(--cream);border-radius:12px;
  padding:12px 8px;text-align:center;
  border:1.5px solid rgba(16,66,55,.07);
}
.stat-n{font-size:1.4rem;font-weight:800;color:var(--green)}
.stat-l{font-size:0.6rem;font-weight:700;color:var(--slate);margin-top:2px;letter-spacing:.05em;text-transform:uppercase}

/* ════════════════════════════════
   ALERTS
════════════════════════════════ */
.alert{
  border-radius:12px;padding:13px 14px;
  font-size:0.81rem;font-weight:500;
  display:flex;gap:10px;align-items:flex-start;
  line-height:1.55;
}
.ai{font-size:.95rem;flex-shrink:0;margin-top:1px}
.a-green{background:var(--green-light);border:1.5px solid #a0cfbf;color:var(--green)}
.a-yellow{background:#fef9e7;border:1.5px solid #f7dc6f;color:#7d6608}
.a-pink{background:#fce8f3;border:1.5px solid var(--pink);color:var(--green)}
.a-red{background:#fdecea;border:1.5px solid #e88;color:#922}

/* ════════════════════════════════
   REWARD ITEMS LIST
════════════════════════════════ */
.reward-list{
  background:var(--cream);border-radius:13px;
  padding:4px 16px;
}
.reward-row{
  display:flex;align-items:center;gap:12px;
  padding:12px 0;
  border-bottom:1px solid var(--border);
  font-size:0.92rem;font-weight:700;color:var(--green);
}
.reward-row:last-child{border-bottom:none}
.reward-row .ri{font-size:1.4rem;width:30px;text-align:center;flex-shrink:0}

/* ════════════════════════════════
   BACK BUTTON
════════════════════════════════ */
.back{
  display:inline-flex;align-items:center;gap:5px;
  background:none;border:none;cursor:pointer;
  color:var(--slate);font-size:0.8rem;font-weight:600;
  padding:8px 16px 0;
  align-self:flex-start;font-family:inherit;
}
.back:hover{color:var(--green)}

/* ════════════════════════════════
   CONFIRM BOX
════════════════════════════════ */
.confirm-box{
  background:var(--cream);border-radius:13px;
  padding:16px 18px;
  border:2px solid var(--pink);
  margin-bottom:16px;
}
.cb-name{font-size:1.15rem;font-weight:800;color:var(--green)}
.cb-phone{font-size:0.82rem;color:var(--slate);margin-top:2px}
.cb-reward{
  margin-top:10px;padding-top:10px;
  border-top:1px solid var(--border);
  font-size:0.82rem;font-weight:700;color:var(--green2);
}

/* ════════════════════════════════
   DONE SCREEN
════════════════════════════════ */
.done-char{
  display:block;
  height:170px;object-fit:contain;
  margin:0 auto 16px;
}

/* ════════════════════════════════
   SECTION DIVIDER LABEL
════════════════════════════════ */
.divlabel{
  text-align:center;
  font-size:0.68rem;font-weight:800;
  color:var(--slate);letter-spacing:.1em;text-transform:uppercase;
  display:flex;align-items:center;gap:10px;
}
.divlabel::before,.divlabel::after{
  content:'';flex:1;height:1px;background:var(--border);
}

/* ════════════════════════════════
   TOAST
════════════════════════════════ */
.toast{
  position:fixed;bottom:22px;left:50%;
  transform:translateX(-50%) translateY(80px);
  background:var(--green);color:var(--white);
  padding:12px 24px;border-radius:30px;
  font-size:0.84rem;font-weight:700;
  transition:transform .28s ease;
  z-index:9999;white-space:nowrap;
  box-shadow:0 4px 18px rgba(16,66,55,.25);
  max-width:90vw;text-align:center;
}
.toast.up{transform:translateX(-50%) translateY(0)}
.toast.t-pink{background:var(--pink);color:var(--green)}
.toast.t-red{background:var(--red)}

/* ════════════════════════════════
   LOADING
════════════════════════════════ */
.loading-wrap{
  display:flex;flex-direction:column;
  align-items:center;padding:48px 20px;gap:0;
}
.dots{display:flex;gap:7px;margin-bottom:16px}
.d{
  width:10px;height:10px;border-radius:50%;
  animation:dUp .55s ease infinite alternate;
}
.d:nth-child(1){background:var(--pink);animation-delay:0s}
.d:nth-child(2){background:var(--green);animation-delay:.15s}
.d:nth-child(3){background:var(--pink);animation-delay:.3s}
@keyframes dUp{from{transform:translateY(0);opacity:.4}to{transform:translateY(-11px);opacity:1}}
.loading-txt{color:var(--slate);font-size:0.83rem;font-weight:600}

/* ════════════════════════════════
   REGISTER HINT
════════════════════════════════ */
.reg-hint{
  font-size:0.73rem;color:var(--slate);
  text-align:center;line-height:1.65;
  padding:0 4px;
}
.reg-hint b{color:var(--green)}
</style>
</head>
<body>

<!-- ══════════════════════════════════════
     S1 · PHONE ENTRY
══════════════════════════════════════ -->
<div class="screen active" id="s-phone">

  <div class="top-header">
    <div class="header-top-label">Loyalty Rewards Program</div>
    <div class="logo-oval">
      <img src="data:image/png;base64," class="logo-img" alt="Emboss Burger Logo">
    </div>
    <div class="branch-pill" id="branch-pill-1"></div>
  </div>

  <div class="content">

    <div class="card">
      <label class="field-label">📱 Enter Your Phone Number</label>
      <div class="field-wrap">
        <span class="f-prefix">🇸🇦</span>
        <input class="input" id="phone-inp"
          type="tel" inputmode="numeric" pattern="[0-9]*"
          placeholder="05XXXXXXXX" maxlength="15"
          autocomplete="tel"
          oninput="numsOnly(this)"
          onkeypress="return numKey(event)"
          onkeydown="if(event.key==='Enter') doPhone()">
      </div>
      <div class="err-text" id="phone-err"></div>
      <button class="btn btn-green" id="phone-btn" onclick="doPhone()" style="margin-top:14px">
        <span class="btn-txt">Check My Stamps →</span>
        <div class="spin"></div>
      </button>
    </div>

    <p class="reg-hint"><b>First visit?</b> Just enter your number — we'll create your account automatically 👋</p>

  </div>
</div>

<!-- ══════════════════════════════════════
     S2 · REGISTER
══════════════════════════════════════ -->
<div class="screen" id="s-register">
  <div class="top-header">
    <div class="header-top-label">Loyalty Rewards Program</div>
    <div class="logo-oval">
      <img src="data:image/png;base64," class="logo-img" alt="Emboss Burger Logo">
    </div>
  </div>

  <button class="back" onclick="go('s-phone')">← Back</button>

  <div class="content" style="padding-top:8px">

    <div class="card">
      <div style="text-align:center;margin-bottom:18px">
        <div style="font-size:1.4rem;margin-bottom:4px">👋</div>
        <div style="font-size:1.1rem;font-weight:800;color:var(--green)">Welcome!</div>
        <div style="font-size:0.8rem;color:var(--slate);margin-top:2px">Let's create your loyalty account</div>
      </div>

      <div class="alert a-pink" style="margin-bottom:18px">
        <span class="ai">📱</span>
        <div>Number: <b id="reg-phone-show"></b><br>
        <span style="font-size:0.73rem;opacity:.8">Your phone number is your loyalty card</span></div>
      </div>

      <label class="field-label">Your First Name</label>
      <input class="input plain" id="name-inp"
        type="text" placeholder="e.g. Ahmed"
        maxlength="40" autocomplete="given-name"
        onkeydown="if(event.key==='Enter') doRegister()">
      <div class="err-text" id="name-err"></div>

      <button class="btn btn-pink" id="reg-btn" onclick="doRegister()" style="margin-top:16px">
        <span class="btn-txt">🎉 Join Emboss Circle</span>
        <div class="spin"></div>
      </button>
      <button class="btn-ghost" onclick="go('s-phone')">Use a different number</button>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════
     S3 · STAMP CARD
══════════════════════════════════════ -->
<div class="screen" id="s-stamps">
  <div class="top-header">
    <div class="header-top-label">Loyalty Rewards Program</div>
    <div class="logo-oval">
      <img src="data:image/png;base64," class="logo-img" alt="Emboss Burger Logo">
    </div>
    <div class="branch-pill" id="branch-pill-3"></div>
  </div>

  <div class="content">

    <!-- Welcome text -->
    <div style="text-align:center;padding:4px 0 2px">
      <div style="font-size:1.3rem;font-weight:800;color:var(--green)" id="wname">Welcome back!</div>
      <div style="font-size:0.8rem;color:var(--slate);margin-top:2px" id="wsub">Olaya Branch</div>
    </div>

    <!-- Stats -->
    <div class="stats">
      <div class="stat"><div class="stat-n" id="sv">0</div><div class="stat-l">Visits</div></div>
      <div class="stat"><div class="stat-n" id="sm">0</div><div class="stat-l">Meals Earned</div></div>
      <div class="stat"><div class="stat-n" id="sl">8</div><div class="stat-l">Stamps Left</div></div>
    </div>

    <!-- Stamp visual card -->
    <div class="stamp-card">
      <div class="sc-top">
        <div class="sc-label">⭐ Your Stamp Card</div>
        <div class="sc-badge" id="sc-badge">8 stamps = free meal</div>
      </div>
      <div class="stamps-grid" id="sgrid"></div>
      <div class="sc-progress" id="sc-prog">0 / 8</div>
      <img src="data:image/png;base64," class="sc-char" alt="">
    </div>

    <!-- Today alert -->
    <div class="alert a-green" id="a-today" style="display:none">
      <span class="ai">✅</span>
      <div><b>Stamp collected today!</b><br>
      <span style="font-size:0.74rem">Come back tomorrow for your next stamp 😊</span></div>
    </div>

    <!-- Reward alert -->
    <div class="alert a-yellow" id="a-reward" style="display:none">
      <span class="ai">🎉</span>
      <div><b>Your free meal is ready!</b><br>
      <span style="font-size:0.74rem">Show this screen to your cashier to claim</span></div>
    </div>

    <!-- Add stamp -->
    <button class="btn btn-pink" id="btn-stamp" onclick="doStamp()" style="display:none">
      <span class="btn-txt">⭐ Add Today's Stamp</span>
      <div class="spin"></div>
    </button>

    <!-- Claim -->
    <button class="btn btn-green" id="btn-claim" onclick="go('s-reward')" style="display:none">
      <span class="btn-txt">🎁 Claim My Free Meal</span>
      <div class="spin"></div>
    </button>

    <button class="btn-ghost" onclick="resetApp()">← Done / New Customer</button>

  </div>
</div>

<!-- ══════════════════════════════════════
     S4 · REWARD
══════════════════════════════════════ -->
<div class="screen" id="s-reward">
  <div class="top-header">
    <div class="header-top-label">Loyalty Rewards Program</div>
    <div class="logo-oval">
      <img src="data:image/png;base64," class="logo-img" alt="Emboss Burger Logo">
    </div>
  </div>

  <!-- Pink celebration header -->
  <div style="width:100%;background:var(--pink);padding:24px 20px;text-align:center;border-bottom:3px solid var(--green)">
    <div style="font-size:3.5rem;margin-bottom:8px;animation:float 2s ease-in-out infinite">🎉</div>
    <div style="font-size:1.55rem;font-weight:800;color:var(--green)" id="reward-title">You earned it!</div>
    <div style="font-size:0.82rem;font-weight:700;color:var(--green);opacity:.7;margin-top:4px">
      Signature Burgers &amp; Signature Taste
    </div>
  </div>
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

  <div class="content">
    <div class="reward-list">
      <div class="reward-row"><span class="ri">🍔</span>1 Classic Burger (your choice)</div>
      <div class="reward-row"><span class="ri">🥤</span>1 Cola</div>
      <div class="reward-row"><span class="ri">🍟</span>1 French Fries</div>
    </div>

    <div class="alert a-yellow">
      <span class="ai">⚠️</span>
      <div><b>Cashier only:</b> Press the confirm button below after preparing the reward. Do not allow the customer to press it.</div>
    </div>

    <button class="btn btn-danger" onclick="go('s-confirm')">
      <span class="btn-txt">CASHIER: Confirm Reward →</span>
      <div class="spin"></div>
    </button>
    <button class="btn-ghost" onclick="go('s-stamps')">← Go Back</button>
  </div>
</div>

<!-- ══════════════════════════════════════
     S5 · CASHIER CONFIRM
══════════════════════════════════════ -->
<div class="screen" id="s-confirm">
  <div class="top-header">
    <div class="header-top-label">Loyalty Rewards Program</div>
    <div class="logo-oval">
      <img src="data:image/png;base64," class="logo-img" alt="Emboss Burger Logo">
    </div>
  </div>

  <button class="back" onclick="go('s-reward')">← Back</button>

  <div class="content" style="padding-top:8px">
    <div class="card">
      <div style="text-align:center;margin-bottom:18px">
        <div style="font-size:2rem;margin-bottom:6px">🔐</div>
        <div style="font-size:1rem;font-weight:800;color:var(--green)">Confirm Reward Redemption</div>
        <div style="font-size:0.78rem;color:var(--slate);margin-top:4px;line-height:1.6">
          Redeeming reward for this customer.<br>
          Their stamp card will reset to zero.
        </div>
      </div>

      <div class="confirm-box">
        <div class="cb-name" id="cb-name">—</div>
        <div class="cb-phone" id="cb-phone">—</div>
        <div class="cb-reward">🍔 Burger &nbsp;+&nbsp; 🥤 Cola &nbsp;+&nbsp; 🍟 Fries</div>
      </div>

      <button class="btn btn-danger" id="confirm-btn" onclick="doConfirm()">
        <span class="btn-txt">✅ Confirm &amp; Redeem Reward</span>
        <div class="spin"></div>
      </button>
      <button class="btn btn-outline" onclick="go('s-reward')" style="margin-top:10px">
        ✕ Cancel
      </button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     S6 · DONE
══════════════════════════════════════ -->
<div class="screen" id="s-done">
  <div class="top-header">
    <div class="header-top-label">Loyalty Rewards Program</div>
    <div class="logo-oval">
      <img src="data:image/png;base64," class="logo-img" alt="Emboss Burger Logo">
    </div>
  </div>

  <div class="content" style="align-items:center;text-align:center;padding-top:24px">
    <img src="data:image/png;base64," class="done-char" alt="Emboss Character">
    <div style="font-size:1.5rem;font-weight:800;color:var(--green);margin-bottom:8px">Enjoy your meal!</div>
    <div style="font-size:0.86rem;color:var(--slate);line-height:1.8;margin-bottom:16px">
      Reward confirmed ✅<br>
      Stamp card reset to zero.<br>
      See you next time!
    </div>
    <img src="data:image/png;base64," style="height:20px;object-fit:contain;opacity:.45;margin-bottom:24px" alt="">
    <button class="btn btn-green" onclick="resetApp()" style="max-width:280px">Done ✓</button>
  </div>
</div>

<!-- ══════════════════════════════════════
     S7 · LOADING
══════════════════════════════════════ -->
<div class="screen" id="s-loading">
  <div class="top-header">
    <div class="header-top-label">Loyalty Rewards Program</div>
    <div class="logo-oval">
      <img src="data:image/png;base64," class="logo-img" alt="Emboss Burger Logo">
    </div>
  </div>
  <div class="content">
    <div class="loading-wrap">
      <div class="dots">
        <div class="d"></div><div class="d"></div><div class="d"></div>
      </div>
      <div class="loading-txt" id="ltxt">Please wait...</div>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
const SUPABASE_URL = 'https://supabase.com/dashboard/project/funkvzxbhpnjgjhvwlbd';
const SUPABASE_KEY = 'sb_publishable_FHRhZkNdWurGEFZMOZ1GHA_vs5Yh0xz';
const STAMPS_NEEDED = 8;
const TIMEOUT = 10000;

const db = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

const BRANCHES = {olaya:'Olaya Branch',masif:'Masif Branch',muruj:'Muruj Branch'};
function getBranch(){
  const p = new URLSearchParams(window.location.search).get('branch');
  if(p && BRANCHES[p.toLowerCase()]) return p.toLowerCase();
  const seg = window.location.pathname.split('/').filter(Boolean).pop();
  if(BRANCHES[seg]) return seg;
  return 'olaya';
}
const BRANCH = getBranch();
const BLABEL = BRANCHES[BRANCH];

let A = {phone:'',cust:null,stamps:0,visits:0,redeemed:0,today:false};

// Set branch labels immediately — no "Loading..." ever shown
(function(){
  const setB = ()=>{
    ['branch-pill-1','branch-pill-3'].forEach(id=>{
      const el=document.getElementById(id);
      if(el) el.textContent=BLABEL;
    });
    const ws=document.getElementById('wsub');
    if(ws) ws.textContent=BLABEL;
  };
  // Run immediately if DOM ready, else wait
  if(document.readyState==='loading'){
    document.addEventListener('DOMContentLoaded',()=>{ setB(); setTimeout(()=>{ const f=document.getElementById('phone-inp'); if(f) f.focus(); },100); });
  } else {
    setB();
    setTimeout(()=>{ const f=document.getElementById('phone-inp'); if(f) f.focus(); },100);
  }
})();

/* ── navigation ── */
function go(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}
function busy(btn,on){
  btn.classList.toggle('busy',on);
  btn.disabled=on;
}

/* ── timeout wrapper ── */
function tw(p){
  return Promise.race([p,
    new Promise((_,r)=>setTimeout(()=>r(new Error('timeout')),TIMEOUT))
  ]);
}

/* ── number input guards ── */
function numKey(e){
  if([8,9,13,27,37,38,39,40,46].includes(e.keyCode)) return true;
  if(e.key>='0'&&e.key<='9') return true;
  e.preventDefault(); return false;
}
function numsOnly(el){ el.value=el.value.replace(/[^0-9]/g,''); }

/* ── PHONE SUBMIT ── */
async function doPhone(){
  const ph = document.getElementById('phone-inp').value.trim();
  const eEl= document.getElementById('phone-err');
  const btn= document.getElementById('phone-btn');

  if(!/^[0-9]{9,15}$/.test(ph)){
    eEl.textContent = ph.length===0
      ? 'Please enter your phone number'
      : 'Numbers only, 9–15 digits please';
    eEl.classList.add('show');
    document.getElementById('phone-inp').classList.add('has-error');
    return;
  }
  eEl.classList.remove('show');
  document.getElementById('phone-inp').classList.remove('has-error');
  busy(btn,true);
  A.phone=ph;

  try{
    const {data,error}=await tw(db.from('customers').select('*').eq('phone',ph).maybeSingle());
    if(error) throw error;
    if(!data){
      document.getElementById('reg-phone-show').textContent=ph;
      document.getElementById('name-inp').value='';
      document.getElementById('name-err').classList.remove('show');
      go('s-register');
    } else {
      A.cust=data; await loadCard();
    }
  } catch(e){
    showToast(e.message==='timeout'
      ? '⚠️ Timeout — check your internet'
      : '⚠️ Connection error. Try again.','t-red');
  } finally { busy(btn,false); }
}

/* ── REGISTER ── */
async function doRegister(){
  const name=document.getElementById('name-inp').value.trim();
  const eEl =document.getElementById('name-err');
  const btn =document.getElementById('reg-btn');
  if(name.length<2){
    eEl.textContent='Please enter your name (min 2 characters)';
    eEl.classList.add('show'); return;
  }
  eEl.classList.remove('show');
  busy(btn,true);

  try{
    const {data:ex}=await tw(db.from('customers').select('phone').eq('phone',A.phone).maybeSingle());
    if(ex){ A.cust=ex; await loadCard(); return; }

    const {data,error}=await tw(
      db.from('customers')
        .insert([{phone:A.phone,name,registered_branch:BRANCH,total_redeemed:0}])
        .select().single()
    );
    if(error) throw error;
    A.cust=data;
    await addStampDB();
    await loadCard(true);
  } catch(e){
    if(e.code==='23505'){ showToast('Already registered','t-red'); go('s-phone'); }
    else showToast('Registration failed. Try again.','t-red');
  } finally { busy(btn,false); }
}

/* ── LOAD CARD ── */
async function loadCard(isNew=false){
  go('s-loading');
  document.getElementById('ltxt').textContent='Loading your stamp card...';
  try{
    const td=todayStr();
    const [r1,r2,r3]=await Promise.all([
      tw(db.from('stamps').select('stamp_date').eq('phone',A.phone).order('stamp_date',{ascending:true})),
      tw(db.from('redemptions').select('redeemed_at').eq('phone',A.phone).order('redeemed_at',{ascending:false}).limit(1)),
      tw(db.from('customers').select('*').eq('phone',A.phone).single())
    ]);
    if(r1.error) throw r1.error;
    if(r3.data) A.cust=r3.data;

    const stamps=r1.data||[];
    const lastRed=(r2.data&&r2.data.length>0)?r2.data[0].redeemed_at.split('T')[0]:null;
    const cycle=lastRed?stamps.filter(s=>s.stamp_date>lastRed):stamps;

    A.stamps  = Math.min(cycle.length,STAMPS_NEEDED);
    A.visits  = stamps.length;
    A.redeemed= A.cust.total_redeemed||0;
    A.today   = cycle.some(s=>s.stamp_date===td);

    renderCard(isNew);
    go('s-stamps');
  } catch(e){
    showToast('Error loading card. Try again.','t-red');
    go('s-phone');
  }
}

/* ── RENDER ── */
function renderCard(anim=false){
  const n=A.stamps, left=Math.max(0,STAMPS_NEEDED-n), c=A.cust;

  document.getElementById('wname').textContent =
    A.visits<=1 ? `Welcome, ${c.name}! 🎉` : `Welcome back, ${c.name}! 👋`;
  document.getElementById('sv').textContent=A.visits;
  document.getElementById('sm').textContent=A.redeemed;
  document.getElementById('sl').textContent=left;
  document.getElementById('sc-badge').textContent =
    n>=STAMPS_NEEDED ? '🎉 REWARD READY!' : `${STAMPS_NEEDED} stamps = free meal`;

  /* stamps grid */
  const grid=document.getElementById('sgrid');
  grid.innerHTML='';
  for(let i=1;i<=STAMPS_NEEDED;i++){
    const d=document.createElement('div');
    d.className='sdot '+(i<=n?'on':'off');
    if(i===n&&anim&&n>0) d.classList.add('pop');
    d.textContent=i<=n?'⭐':'';
    grid.appendChild(d);
  }

  /* progress */
  const pg=document.getElementById('sc-prog');
  pg.innerHTML=n>=STAMPS_NEEDED
    ? '<b>🎉 Complete! Claim your reward below</b>'
    : `<b>${n}</b> of ${STAMPS_NEEDED} · <b>${left} more</b> for your free meal`;

  /* alerts & buttons */
  const ids=['a-today','a-reward','btn-stamp','btn-claim'];
  ids.forEach(id=>document.getElementById(id).style.display='none');

  if(n>=STAMPS_NEEDED){
    document.getElementById('a-reward').style.display='flex';
    document.getElementById('btn-claim').style.display='flex';
    document.getElementById('cb-name').textContent=c.name;
    document.getElementById('cb-phone').textContent=A.phone;
    document.getElementById('reward-title').textContent=`${c.name}, you earned it!`;
  } else if(A.today){
    document.getElementById('a-today').style.display='flex';
  } else {
    document.getElementById('btn-stamp').style.display='flex';
  }
}

/* ── ADD STAMP ── */
async function doStamp(){
  const btn=document.getElementById('btn-stamp');
  busy(btn,true);
  try{
    const td=todayStr();
    const {data:ex}=await tw(db.from('stamps').select('id').eq('phone',A.phone).eq('stamp_date',td).limit(1));
    if(ex&&ex.length>0){ A.today=true; renderCard(); showToast('Already stamped today!','t-pink'); return; }
    await addStampDB();
    A.stamps++; A.visits++; A.today=true;
    renderCard(true);
    const left=STAMPS_NEEDED-A.stamps;
    if(A.stamps>=STAMPS_NEEDED) showToast('🎉 Card complete! Claim your free meal!','t-pink');
    else showToast(`⭐ Stamp added! ${left} more to go!`);
  } catch(e){
    showToast('Error adding stamp. Try again.','t-red');
  } finally { busy(btn,false); }
}

async function addStampDB(){
  const {error}=await tw(db.from('stamps').insert([{phone:A.phone,branch:BRANCH,stamp_date:todayStr()}]));
  if(error) throw error;
}

/* ── CONFIRM REWARD ── */
async function doConfirm(){
  const btn=document.getElementById('confirm-btn');
  busy(btn,true);
  try{
    const {error:e1}=await tw(db.from('redemptions').insert([{phone:A.phone,branch:BRANCH,redeemed_at:new Date().toISOString()}]));
    if(e1) throw e1;
    const {error:e2}=await tw(db.from('customers').update({total_redeemed:(A.cust.total_redeemed||0)+1}).eq('phone',A.phone));
    if(e2) throw e2;
    go('s-done');
  } catch(e){
    showToast('Error confirming. Try again.','t-red');
  } finally { busy(btn,false); }
}

/* ── RESET ── */
function resetApp(){
  A={phone:'',cust:null,stamps:0,visits:0,redeemed:0,today:false};
  document.getElementById('phone-inp').value='';
  document.getElementById('phone-err').classList.remove('show');
  document.getElementById('phone-inp').classList.remove('has-error');
  go('s-phone');
  setTimeout(()=>document.getElementById('phone-inp').focus(),200);
}

/* ── HELPERS ── */
function todayStr(){ return new Date().toISOString().split('T')[0]; }

let tTmr;
function showToast(msg,cls=''){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.className='toast '+(cls||'');
  t.classList.add('up');
  clearTimeout(tTmr);
  tTmr=setTimeout(()=>t.classList.remove('up'),3400);
}
</script>
</body>
</html>
